# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
Mod/SourceArt/**/*.png
Tests/SourceArt/**/*.png
Mod/SourceArt/**/*.tga
Tests/SourceArt/**/*.tga

# Binary Files
Mod/Binaries/*
Tests/Binaries/*
Mod/Plugins/*/Binaries/*
Tests/Plugins/*/Binaries/*

# Builds
Mod/Build/*
Tests/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Mod/Build/*/
!Tests/Build/*/
Mod/Build/*/**
Tests/Build/*/**
!Mod/Build/*/PakBlacklist*.txt
!Tests/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Mod/Build/**/*.ico
!Tests/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Mod/Saved/*
Tests/Saved/*

# Compiled source files for the engine to use
Mod/Intermediate/*
Tests/Intermediate/*
Mod/Plugins/*/Intermediate/*
Tests/Plugins/*/Intermediate/*

# Cache files for the editor to use
Mod/DerivedDataCache/*
Tests/DerivedDataCache/*